rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Top-level wildcard - deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /companies/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /profiles/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /roles/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /categories/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /approvals/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /budgets/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /payables/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /receivables/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /employees/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /payroll_runs/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /payroll_items/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /attachments/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /audit_logs/{id} {
      allow read, write: if request.auth != null;
    }

    match /appData/{id} {
      allow read, write: if true;
    }
  }
}
