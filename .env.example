# Required for the application's OpenAI-powered finance features.
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Default balances capability, latency, and cost for this application.
OPENAI_MODEL="gpt-5.4-mini"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local development DB settings (copy to .env and fill in)
SQL_HOST=localhost
SQL_USER=your_db_user
SQL_PASSWORD=your_db_password
SQL_DB_NAME=your_db_name

# NODE_ENV=development
